# =============================================================================
# Variant: nvfp4-default  (DO NOT USE in production on Thor — for validation only)
# Demonstrates Framework 01's 0.10 score: NVFP4 has no native silicon on sm_110,
# the kernel falls back to FlashInferCutlassNvFp4LinearKernel (CUTLASS path),
# resulting in ~30x slowdown vs the FP8 + MTP-1 path on the same hardware.
# =============================================================================

HF_TOKEN=hf_replace_with_your_token
WORKSPACE=$HOME/thor-llm-deploy
VLLM_PORT=8000
MODEL_ID=RedHatAI/Qwen3.6-35B-A3B-NVFP4
VLLM_IMAGE=vllm/vllm-openai:nightly-aarch64
CONTAINER_NAME=qwen36-nvfp4
VLLM_API_KEY=sk-replace-with-your-key

MAX_MODEL_LEN=8192
MAX_NUM_BATCHED_TOKENS=16384
MAX_NUM_SEQS=8
GPU_MEM_UTIL=0.70
KV_CACHE_DTYPE=auto
ENABLE_PREFIX_CACHE=false
SPEC_CONFIG=
LIMIT_MM_PER_PROMPT={"image":0,"video":0}

# enforce-eager for safe first launch on novel hardware
EXTRA_VLLM_ARGS=--enforce-eager
