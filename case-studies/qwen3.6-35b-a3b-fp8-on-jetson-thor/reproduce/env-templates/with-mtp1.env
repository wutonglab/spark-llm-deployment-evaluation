# =============================================================================
# Variant: with-mtp1  (Spark final config replicated on Thor)
# Qwen3.6-35B-A3B-FP8 + MTP-1 + KV-cache FP8 + Spark-style 16384 batched-tokens
# Expected single-request 1024-output on Thor: ~57 tok/s (vs Spark's ~61)
# Provided for comparison against the `thor-tuned` variant.
# =============================================================================

HF_TOKEN=hf_replace_with_your_token
WORKSPACE=$HOME/thor-llm-deploy
VLLM_PORT=8000
MODEL_ID=Qwen/Qwen3.6-35B-A3B-FP8
VLLM_IMAGE=vllm/vllm-openai:nightly-aarch64
CONTAINER_NAME=qwen36-fp8
VLLM_API_KEY=sk-replace-with-your-key

MAX_MODEL_LEN=262144
MAX_NUM_BATCHED_TOKENS=16384
MAX_NUM_SEQS=8
GPU_MEM_UTIL=0.75
KV_CACHE_DTYPE=fp8
ENABLE_PREFIX_CACHE=true
SPEC_CONFIG={"method":"mtp","num_speculative_tokens":1}
LIMIT_MM_PER_PROMPT={"image":0,"video":0}

EXTRA_VLLM_ARGS=
