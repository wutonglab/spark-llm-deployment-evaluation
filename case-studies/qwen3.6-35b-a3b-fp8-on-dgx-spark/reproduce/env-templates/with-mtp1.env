# =============================================================================
# Variant: with-mtp1  ⭐ recommended production config
# Qwen3.6-35B-A3B-FP8 + MTP-1 speculative + KV-cache FP8 + default attention
# Expected single-request 1024-output: ~61 tok/s
# =============================================================================

# ---- Required ----
HF_TOKEN=hf_replace_with_your_token
WORKSPACE=$HOME/spark-llm-deploy
VLLM_PORT=8000
MODEL_ID=Qwen/Qwen3.6-35B-A3B-FP8
VLLM_IMAGE=nvcr.io/nvidia/vllm:26.03.post1-py3
CONTAINER_NAME=qwen36-fp8

# ---- Variant knobs ----
MAX_MODEL_LEN=262144
MAX_NUM_BATCHED_TOKENS=16384
GPU_MEM_UTIL=0.85
KV_CACHE_DTYPE=fp8
ATTENTION_BACKEND=
ENABLE_PREFIX_CACHE=true
SPEC_CONFIG={"method":"mtp","num_speculative_tokens":1}

# Any extra args to append to `vllm serve` (space-separated)
EXTRA_VLLM_ARGS=
