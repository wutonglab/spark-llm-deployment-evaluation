# Copy to .env and fill in. .env is gitignored.

# ===== Required for agent evaluation =====
# Pick one provider; agent supports OpenAI + Anthropic.
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ===== Required for benchmark stage (Stage 4) =====
# vLLM endpoint to benchmark against (OpenAI-compatible).
# If running benchmark on the same host: http://localhost:8000/v1
# If targeting a remote DGX Spark via SSH tunnel or LAN: http://<host>:<port>/v1
VLLM_BASE_URL=http://localhost:8000/v1
# Model id served by vLLM (must match --served-model-name)
MODEL_ID=Qwen/Qwen3.6-35B-A3B-FP8

# ===== Required to launch a vLLM container locally via tools/deploy/launch.sh =====
# HuggingFace token for downloading gated models
HF_TOKEN=hf_...
# Workspace where model weights + container volumes live
WORKSPACE=~/spark-llm-deploy
# Port to expose vLLM on
VLLM_PORT=8000
# vLLM container image (pin a digest in production)
VLLM_IMAGE=nvcr.io/nvidia/vllm:26.03.post1-py3
# Which variant config to launch (see tools/deploy/variant-configs/)
VARIANT=with-mtp1

# ===== Optional: remote benchmark target =====
# If your Spark host is remote, agent can SSH in to run docker / nvidia-smi.
# TARGET_HOST=user@your-spark-host
# TARGET_SSH_KEY=~/.ssh/id_rsa

# ===== Optional: agent behavior =====
# LLM_MODEL=gpt-4o                  # OpenAI model (default: gpt-4o)
# LLM_MODEL=claude-3-5-sonnet-latest  # Anthropic model
# AGENT_MAX_TURNS_PER_STAGE=20      # Bound tool-use loop
