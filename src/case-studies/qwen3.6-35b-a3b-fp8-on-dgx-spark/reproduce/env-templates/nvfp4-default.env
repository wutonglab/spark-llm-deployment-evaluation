# =============================================================================
# Variant: nvfp4-default (vendor NVFP4 with mainline vLLM nvcr image)
# This is the "naive NVFP4" path that Framework 01 predicts will be slow on sm_121.
# Expected single-request 1024-output: ~12 tok/s (validates the prediction)
#
# Note: requires the NVFP4 variant of the model. If the official Qwen org doesn't
# publish FP4 weights yet, use a community NVFP4 fork (e.g. RedHatAI namespace).
# =============================================================================

HF_TOKEN=hf_replace_with_your_token
WORKSPACE=$HOME/spark-llm-deploy
VLLM_PORT=8000
MODEL_ID=RedHatAI/Qwen3.6-35B-A3B-NVFP4   # community NVFP4 fork — adjust as available
VLLM_IMAGE=nvcr.io/nvidia/vllm:26.03.post1-py3
CONTAINER_NAME=qwen36-nvfp4

MAX_MODEL_LEN=262144
MAX_NUM_BATCHED_TOKENS=16384
GPU_MEM_UTIL=0.85
KV_CACHE_DTYPE=fp8
ATTENTION_BACKEND=
ENABLE_PREFIX_CACHE=true
SPEC_CONFIG=

# Quantization auto-detected from model card metadata
EXTRA_VLLM_ARGS=
