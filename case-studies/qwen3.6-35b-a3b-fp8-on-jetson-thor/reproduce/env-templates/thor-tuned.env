# =============================================================================
# Variant: thor-tuned  ⭐ recommended Jetson Thor production config
# Qwen3.6-35B-A3B-FP8 + MTP-1 + KV-cache FP8 + prefix-caching
# + max-num-seqs 64 + max-num-batched-tokens 32768 (NOT Spark's 16384)
# Expected single-request 1024-output: ~67 tok/s
# Expected c=16 / 512-out aggregate: ~303 tok/s
# Target hardware: NVIDIA Jetson Thor (sm_110), 128 GB LPDDR5X
# =============================================================================

# ---- Required ----
HF_TOKEN=hf_replace_with_your_token
WORKSPACE=$HOME/thor-llm-deploy
VLLM_PORT=8000
MODEL_ID=Qwen/Qwen3.6-35B-A3B-FP8
VLLM_IMAGE=vllm/vllm-openai:nightly-aarch64
CONTAINER_NAME=qwen36-fp8

# Required: API key for the served endpoint (vLLM enforces it)
VLLM_API_KEY=sk-replace-with-your-key

# ---- Variant knobs ----
MAX_MODEL_LEN=262144
MAX_NUM_BATCHED_TOKENS=32768
MAX_NUM_SEQS=64
GPU_MEM_UTIL=0.75
KV_CACHE_DTYPE=fp8
ENABLE_PREFIX_CACHE=true
SPEC_CONFIG={"method":"mtp","num_speculative_tokens":1}
LIMIT_MM_PER_PROMPT={"image":4,"video":1}

# Any extra args to append to `vllm serve` (space-separated)
EXTRA_VLLM_ARGS=
